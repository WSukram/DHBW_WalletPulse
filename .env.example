# ── Required ────────────────────────────────────────────────────────────────

# HMAC secret for signing JWT tokens. Must be a long random string.
# Generate one: openssl rand -base64 48
JWT_SECRET=change_this_in_production

# ── Strongly recommended ─────────────────────────────────────────────────────

# CoinGecko Demo API key — required for reliable live & historical prices.
# Without this the free tier is severely rate-limited and price lookups will fail.
# Get a free key at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# ── Required for on-chain import ─────────────────────────────────────────────

# Etherscan — required for Ethereum (ETH + ERC-20) import.
# Get a free key at: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Helius — required for Solana (SOL + SPL) import.
# Get a free key at: https://helius.dev
HELIUS_API_KEY=

# Bitcoin import uses Blockstream's public API — no key needed.

# ── Optional ──────────────────────────────────────────────────────────────────

# PostgreSQL password. The default works fine for local use.
DB_PASSWORD=postgres
